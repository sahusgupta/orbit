rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(playerId) {
      return isSignedIn() && request.auth.uid == playerId;
    }

    function hasEmail() {
      return isSignedIn() && request.auth.token.email is string;
    }

    function ownsStoredClub(clubId) {
      return hasEmail()
        && exists(/databases/$(database)/documents/clubStates/$(clubId))
        && (
          get(/databases/$(database)/documents/clubStates/$(clubId)).data.state.settings.accountLogin.username == request.auth.token.email
          || get(/databases/$(database)/documents/clubStates/$(clubId)).data.state.settings.clubAccount.email == request.auth.token.email
        );
    }

    function createsOwnedClub() {
      return hasEmail()
        && request.resource.data.state.settings.accountLogin.username == request.auth.token.email;
    }

    function isClubAdmin(clubId) {
      return isSignedIn()
        && (
          ownsStoredClub(clubId)
          ||
          request.auth.token.admin == true
          || request.auth.token.clubAdmin == true
          || request.auth.token.clubId == clubId
          || (request.auth.token.clubIds != null && request.auth.token.clubIds[clubId] == true)
        );
    }

    function playerDocPath(playerId) {
      return /databases/$(database)/documents/players/$(playerId);
    }

    function hasActivePlayerPremium(playerId) {
      return isSelf(playerId)
        && exists(playerDocPath(playerId))
        && (
          get(playerDocPath(playerId)).data.premium.status == 'active'
          || get(playerDocPath(playerId)).data.subscriptionStatus == 'active'
        );
    }

    function doesNotChangeServerManagedBilling() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny([
        'premium',
        'stripeCustomerId',
        'stripeSubscriptionId',
        'subscriptionStatus',
        'subscriptionCurrentPeriodEnd'
      ]);
    }

    function hasNoServerManagedBilling() {
      return !request.resource.data.keys().hasAny([
        'premium',
        'stripeCustomerId',
        'stripeSubscriptionId',
        'subscriptionStatus',
        'subscriptionCurrentPeriodEnd'
      ]);
    }

    function isPendingPlayerRequest(clubId, requestType) {
      return request.resource.data.clubId == clubId
        && request.resource.data.type == requestType
        && request.resource.data.status == 'pending'
        && request.resource.data.id is string
        && request.resource.data.player.id is string
        && request.resource.data.player.name is string
        && request.resource.data.player.email is string
        && request.resource.data.requestedAt is string
        && request.resource.data.id.size() > 0
        && request.resource.data.player.id.size() > 0
        && request.resource.data.player.name.size() > 0;
    }

    function isPrivateGameListing(gameId) {
      return request.resource.data.id == gameId
        && request.resource.data.status == 'Open'
        && request.resource.data.hostPlayerId is string
        && request.resource.data.hostPlayerPath == 'players/' + request.resource.data.hostPlayerId
        && request.resource.data.hostPlayerName is string
        && request.resource.data.hostPlayerEmail is string
        && request.resource.data.name is string
        && request.resource.data.location is string
        && request.resource.data.createdAt is string
        && request.resource.data.name.size() > 0
        && request.resource.data.location.size() > 0
        && request.resource.data.hostPlayerId.size() > 0;
    }

    function marksRequestAppliedOnly() {
      return resource.data.status == 'pending'
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['status', 'appliedAt'])
        && request.resource.data.status == 'applied';
    }

    match /clubStates/{clubId} {
      allow read, update: if isClubAdmin(clubId);
      allow create: if createsOwnedClub() || isClubAdmin(clubId);
      allow delete: if false;

      match /membershipRequests/{requestId} {
        allow create: if isPendingPlayerRequest(clubId, 'membership-request')
          && isSelf(request.resource.data.player.id);
        allow read: if isClubAdmin(clubId) || isSelf(resource.data.player.id);
        allow update: if isClubAdmin(clubId) && marksRequestAppliedOnly();
        allow delete: if false;
      }

      match /waitlistRequests/{requestId} {
        allow create: if isPendingPlayerRequest(clubId, 'waitlist-request')
          && isSelf(request.resource.data.player.id)
          && request.resource.data.gameId is string
          && request.resource.data.gameId.size() > 0;
        allow read: if isClubAdmin(clubId) || isSelf(resource.data.player.id);
        allow update: if isClubAdmin(clubId) && marksRequestAppliedOnly();
        allow delete: if false;
      }
    }

    match /clubs/{clubId} {
      allow read: if true;
      allow create, update: if isClubAdmin(clubId);
      allow delete: if false;

      match /games/{gameId} {
        allow read: if true;
        allow create, update, delete: if isClubAdmin(clubId);
      }

      match /players/{playerId} {
        allow read, create, update, delete: if isClubAdmin(clubId);
      }

      match /memberships/{membershipId} {
        allow read: if isClubAdmin(clubId) || isSelf(resource.data.playerId);
        allow create, update, delete: if isClubAdmin(clubId);
      }

      match /waitlists/{waitlistId} {
        allow read: if isClubAdmin(clubId) || isSelf(resource.data.playerId);
        allow create, update, delete: if isClubAdmin(clubId);
      }

      match /notifications/{notificationId} {
        allow read: if true;
        allow create, update, delete: if isClubAdmin(clubId);
      }

      match /tournaments/{tournamentId} {
        allow read: if true;
        allow create, update, delete: if isClubAdmin(clubId);
      }

      match /tournamentRegistrations/{registrationId} {
        allow read: if isClubAdmin(clubId) || (isSignedIn() && resource.data.playerId == request.auth.uid);
        allow create: if isSignedIn()
          && request.resource.data.playerId == request.auth.uid
          && request.resource.data.clubId == clubId
          && request.resource.data.status == 'registered'
          && request.resource.data.rebuys == 0
          && request.resource.data.addOns == 0
          && request.resource.data.id == registrationId
          && exists(/databases/$(database)/documents/clubs/$(clubId)/tournaments/$(request.resource.data.tournamentId))
          && get(/databases/$(database)/documents/clubs/$(clubId)/tournaments/$(request.resource.data.tournamentId)).data.registrationStatus == 'open';
        allow update: if isClubAdmin(clubId);
        allow delete: if isClubAdmin(clubId)
          || (isSignedIn()
            && resource.data.playerId == request.auth.uid
            && get(/databases/$(database)/documents/clubs/$(clubId)/tournaments/$(resource.data.tournamentId)).data.unregisterAllowed == true
            && request.time < timestamp(get(/databases/$(database)/documents/clubs/$(clubId)/tournaments/$(resource.data.tournamentId)).data.startsAt));
      }

      match /transactions/{transactionId} {
        allow read: if isClubAdmin(clubId) || (isSignedIn() && resource.data.playerId == request.auth.uid);
        allow create, update, delete: if false;
      }

      match /pushTokens/{playerId} {
        allow read, create, update, delete: if false;
      }

      match /membershipRequests/{requestId} {
        allow create: if isPendingPlayerRequest(clubId, 'membership-request')
          && isSelf(request.resource.data.player.id);
        allow read: if isClubAdmin(clubId) || isSelf(resource.data.player.id);
        allow update: if isClubAdmin(clubId) && marksRequestAppliedOnly();
        allow delete: if false;
      }

      match /waitlistRequests/{requestId} {
        allow create: if isPendingPlayerRequest(clubId, 'waitlist-request')
          && isSelf(request.resource.data.player.id)
          && request.resource.data.gameId is string
          && request.resource.data.gameId.size() > 0;
        allow read: if isClubAdmin(clubId) || isSelf(resource.data.player.id);
        allow update: if isClubAdmin(clubId) && marksRequestAppliedOnly();
        allow delete: if false;
      }
    }

    match /players/{playerId} {
      allow create: if isSelf(playerId) && hasNoServerManagedBilling();
      allow update: if isSelf(playerId) && doesNotChangeServerManagedBilling();
      allow read: if isSelf(playerId);
      allow delete: if false;

      match /members/{memberId} {
        allow read: if true;
        allow create, update, delete: if false;
      }
    }

    match /games/{rootDocument} {
      allow read: if true;
      allow create, update, delete: if false;

      match /{clubName}/{gameId} {
        allow read: if true;
        allow create, update, delete: if false;
      }
    }

    match /privateGames/{gameId} {
      allow read: if true;
      allow create: if isPrivateGameListing(gameId)
        && isSelf(request.resource.data.hostPlayerId)
        && hasActivePlayerPremium(request.resource.data.hostPlayerId)
        && !request.resource.data.keys().hasAny(['hostPlayerEmail']);
      allow update, delete: if false;
    }
  }
}
