{
  "name": "orbit-player",
  "version": "0.1.13",
  "private": true,
  "main": "expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "ios": "expo start --ios",
    "android": "expo start --android",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "rules:deploy": "npx firebase-tools deploy --only firestore:rules,firestore:indexes",
    "build:preview": "npx eas-cli build --profile preview",
    "build:production": "npx eas-cli build --profile production"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "expo": "~54.0.0",
    "expo-asset": "~12.0.13",
    "expo-auth-session": "~7.0.11",
    "expo-constants": "~18.0.13",
    "expo-font": "~14.0.12",
    "expo-linear-gradient": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "~15.0.11",
    "firebase": "^12.13.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-maps": "1.20.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-web": "^0.21.2"
  },
  "devDependencies": {
    "@types/react": "~19.1.10",
    "typescript": "~5.9.2"
  },
  "overrides": {
    "shell-quote": "^1.8.4",
    "uuid": "^11.1.1"
  }
}
